{
  "name": "authpal",
  "version": "1.5.13",
  "description": "An authentication and authorization library for express applications and clients",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "rm -rf lib && tsc",
    "test": "echo 'switched to vitest, should refacor tests'",
    "test:old": "npm run test-server && npm run test-client",
    "test-server": "ts-node node_modules/jasmine/bin/jasmine --reporter=jasmine-ts-console-reporter --config=jasmine.server.json",
    "test-client": "ts-node node_modules/jasmine/bin/jasmine --reporter=jasmine-ts-console-reporter --config=client/jasmine.client.json"
  },
  "files": [
    "lib/**/*.js",
    "lib/**/*.d.ts"
  ],
  "author": "eltharynd",
  "keywords": [
    "node",
    "nodejs",
    "node.js",
    "express",
    "passport",
    "typescript",
    "auth",
    "authentication",
    "authorization",
    "secure",
    "jwt",
    "security",
    "server",
    "server side"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/eltharynd/authpal"
  },
  "license": "MIT",
  "dependencies": {
    "cookie": "^1.1.1",
    "jsonwebtoken": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "rxjs": "^7.8.2",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/cookie": "^1.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jasmine": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "body-parser": "^2.3.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "jasmine": "^6.3.0",
    "jasmine-supertest": "^1.0.0",
    "jasmine-ts-console-reporter": "^3.1.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
