{
  "include": ["src/**/*.ts"],
  "compilerOptions": {
    "declaration": true,
    "module": "preserve",
    "moduleResolution": "bundler",
    "noImplicitAny": false,
    "outDir": "lib",
    "resolveJsonModule": true,
    "rootDir": "src",
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "target": "es2015"
  }
}
